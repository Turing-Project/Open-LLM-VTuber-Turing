diff --git a/src/renderer/src/hooks/canvas/use-live2d-mouse-tracking.ts b/src/renderer/src/hooks/canvas/use-live2d-mouse-tracking.ts
new file mode 100644
index 0000000..0d5a30e
--- /dev/null
