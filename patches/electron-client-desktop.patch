@@ -0,0 +1,103 @@
+/* eslint-disable no-underscore-dangle */
+import { RefObject, useEffect, useRef } from 'react';
+import { ModelInfo } from '@/context/live2d-config-context';
+import { LAppDelegate } from '../../../WebSDK/src/lappdelegate';
+
+const RETURN_TO_CENTER_DELAY_MS = 700;
+const FOLLOW_SMOOTHING = 0.18;
+const TRACK_LIMIT = 0.95;
+
+interface Props {
+  modelInfo: ModelInfo | undefined;
+  canvasRef: RefObject<HTMLCanvasElement>;
+  enabled?: boolean;
+}
+
+const clamp = (value: number): number => Math.max(-TRACK_LIMIT, Math.min(TRACK_LIMIT, value));
+
+function pointerToModel(canvas: HTMLCanvasElement, clientX: number, clientY: number) {
+  const view = LAppDelegate.getInstance()?.getView?.();
+  if (!view?._deviceToScreen) return null;
+
+  const rect = canvas.getBoundingClientRect();
+  if (!rect.width || !rect.height) return null;
+  const scale = canvas.width / rect.width || 1;
+  const deviceX = (clientX - rect.left) * scale;
+  const deviceY = (clientY - rect.top) * scale;
+  return {
+    x: clamp(view._deviceToScreen.transformX(deviceX)),
+    y: clamp(view._deviceToScreen.transformY(deviceY)),
+  };
+}
+
+export function useLive2DMouseTracking({ modelInfo, canvasRef, enabled = true }: Props) {
+  const target = useRef({ x: 0, y: 0 });
+  const current = useRef({ x: 0, y: 0 });
+  const animationFrame = useRef<number | null>(null);
+  const centerTimer = useRef<ReturnType<typeof setTimeout> | null>(null);
+
+  useEffect(() => {
+    const active = enabled
+      && modelInfo?.pointerInteractive !== false
+      && modelInfo?.mouseTracking !== false;
+
+    const getModel = () => (window as any).getLAppAdapter?.()?.getModel?.();
+
+    const reset = () => {
+      if (animationFrame.current !== null) cancelAnimationFrame(animationFrame.current);
+      animationFrame.current = null;
+      if (centerTimer.current) clearTimeout(centerTimer.current);
+      centerTimer.current = null;
+      getModel()?.setDragging?.(0, 0);
+      target.current = { x: 0, y: 0 };
+      current.current = { x: 0, y: 0 };
+    };
+
+    if (!active) {
+      reset();
+      return reset;
+    }
+
+    const animate = () => {
+      const model = getModel();
+      if (model?.setDragging) {
+        current.current = {
+          x: current.current.x + (target.current.x - current.current.x) * FOLLOW_SMOOTHING,
+          y: current.current.y + (target.current.y - current.current.y) * FOLLOW_SMOOTHING,
+        };
+        model.setDragging(current.current.x, current.current.y);
+      }
+      animationFrame.current = requestAnimationFrame(animate);
+    };
+
+    const scheduleCenter = () => {
+      if (centerTimer.current) clearTimeout(centerTimer.current);
+      centerTimer.current = setTimeout(() => {
+        target.current = { x: 0, y: 0 };
+      }, RETURN_TO_CENTER_DELAY_MS);
+    };
+
+    const handlePointerMove = (event: PointerEvent) => {
+      const canvas = canvasRef.current;
+      if (!canvas || event.buttons !== 0) return;
+      const position = pointerToModel(canvas, event.clientX, event.clientY);
+      if (position) {
+        target.current = position;
+        scheduleCenter();
+      }
+    };
+
+    const center = () => { target.current = { x: 0, y: 0 }; };
+    animationFrame.current = requestAnimationFrame(animate);
+    window.addEventListener('pointermove', handlePointerMove, { passive: true });
+    window.addEventListener('pointerleave', center);
+    window.addEventListener('blur', center);
+
+    return () => {
+      window.removeEventListener('pointermove', handlePointerMove);
+      window.removeEventListener('pointerleave', center);
+      window.removeEventListener('blur', center);
+      reset();
+    };
+  }, [canvasRef, enabled, modelInfo?.pointerInteractive, modelInfo?.mouseTracking, modelInfo?.url]);
+}
