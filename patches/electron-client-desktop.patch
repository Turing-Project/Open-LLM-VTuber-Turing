diff --git a/src/main/backend-manager.ts b/src/main/backend-manager.ts
new file mode 100644
index 0000000..78a2334
--- /dev/null
+++ b/src/main/backend-manager.ts
@@ -0,0 +1,107 @@
+import { app } from 'electron';
+import {
+  appendFileSync, cpSync, existsSync, mkdirSync, openSync, readFileSync, writeFileSync,
+} from 'fs';
+import { createConnection } from 'net';
+import { join } from 'path';
+import { ChildProcess, spawn, spawnSync } from 'child_process';
+
+const BACKEND_VERSION = '1.2.1-electron-1';
+
+export class BackendManager {
+  private process: ChildProcess | null = null;
+
+  private readonly dataRoot = join(app.getPath('userData'), 'backend');
+
+  private readonly logPath = join(app.getPath('userData'), 'backend.log');
+
+  private get templateRoot(): string {
+    return app.isPackaged
+      ? join(process.resourcesPath, 'backend')
+      : join(app.getAppPath(), 'backend');
+  }
+
+  private prepareBackend(): void {
+    const marker = join(this.dataRoot, '.electron-backend-version');
+    if (existsSync(marker)
+      && readFileSync(marker, 'utf8').trim() === BACKEND_VERSION) return;
+
+    if (!existsSync(this.templateRoot)) {
+      throw new Error(`Backend resources not found: ${this.templateRoot}`);
+    }
+
+    mkdirSync(this.dataRoot, { recursive: true });
+    const configPath = join(this.dataRoot, 'conf.yaml');
+    const existingConfig = existsSync(configPath) ? readFileSync(configPath) : null;
+    cpSync(this.templateRoot, this.dataRoot, { recursive: true, force: true });
+    if (existingConfig) writeFileSync(configPath, existingConfig);
+    writeFileSync(marker, BACKEND_VERSION, 'utf8');
+  }
+
+  private readPort(): number {
+    const config = readFileSync(join(this.dataRoot, 'conf.yaml'), 'utf8');
+    const systemConfig = config.split('character_config:', 1)[0];
+    const match = systemConfig.match(/^\s*port:\s*(\d+)/m);
+    return match ? Number(match[1]) : 12393;
+  }
+
+  private portIsOpen(port: number): Promise<boolean> {
+    return new Promise((resolve) => {
+      const socket = createConnection({ host: '127.0.0.1', port });
+      socket.setTimeout(500);
+      socket.once('connect', () => {
+        socket.destroy();
+        resolve(true);
+      });
+      const fail = (): void => {
+        socket.destroy();
+        resolve(false);
+      };
+      socket.once('error', fail);
+      socket.once('timeout', fail);
+    });
+  }
+
+  async start(): Promise<void> {
+    this.prepareBackend();
+    const port = this.readPort();
+    if (await this.portIsOpen(port)) return;
+
+    const uv = join(this.dataRoot, 'runtime', 'uv.exe');
+    if (!existsSync(uv)) throw new Error(`uv.exe not found: ${uv}`);
+
+    const runtimeRoot = join(app.getPath('userData'), 'runtime');
+    mkdirSync(runtimeRoot, { recursive: true });
+    appendFileSync(this.logPath, `\n[Electron] Starting backend at ${new Date().toISOString()}\n`);
+    const logFd = openSync(this.logPath, 'a');
+    this.process = spawn(uv, ['run', 'run_server.py'], {
+      cwd: this.dataRoot,
+      windowsHide: true,
+      stdio: ['ignore', logFd, logFd],
+      env: {
+        ...process.env,
+        UV_CACHE_DIR: join(runtimeRoot, 'uv-cache'),
+        UV_PYTHON_INSTALL_DIR: join(runtimeRoot, 'python'),
+      },
+    });
+
+    const deadline = Date.now() + 15 * 60 * 1000;
+    while (Date.now() < deadline) {
+      if (await this.portIsOpen(port)) return;
+      if (this.process.exitCode !== null) {
+        throw new Error(`Backend exited early. See log: ${this.logPath}`);
+      }
+      await new Promise((resolve) => setTimeout(resolve, 500));
+    }
+    throw new Error(`Backend startup timed out. See log: ${this.logPath}`);
+  }
+
+  stop(): void {
+    if (!this.process?.pid || this.process.exitCode !== null) return;
+    spawnSync('taskkill', ['/PID', String(this.process.pid), '/T', '/F'], {
+      windowsHide: true,
+      stdio: 'ignore',
+    });
+    this.process = null;
+  }
+}
