diff --git a/src/renderer/src/context/game-watch-context.tsx b/src/renderer/src/context/game-watch-context.tsx
new file mode 100644
index 0000000..a9647cd
--- /dev/null
+++ b/src/renderer/src/context/game-watch-context.tsx
@@ -0,0 +1,122 @@
+import {
+  createContext, ReactNode, useCallback, useContext, useEffect, useMemo, useRef,
+} from 'react';
+import { useLocalStorage } from '@/hooks/utils/use-local-storage';
+import { useTriggerSpeak } from '@/hooks/utils/use-trigger-speak';
+import { useAiState, AiStateEnum } from '@/context/ai-state-context';
+import { useWebSocket } from '@/context/websocket-context';
+import { useScreenCaptureContext } from '@/context/screen-capture-context';
+
+export interface GameWatchSettings {
+  enabled: boolean;
+  intervalSeconds: number;
+  autoStartScreenCapture: boolean;
+  commentStyle: string;
+}
+
+interface GameWatchContextType {
+  settings: GameWatchSettings;
+  updateSettings: (settings: GameWatchSettings) => void;
+}
+
+const defaultSettings: GameWatchSettings = {
+  enabled: false,
+  intervalSeconds: 120,
+  autoStartScreenCapture: true,
+  commentStyle: 'playful_praise_when_good',
+};
+
+const GameWatchContext = createContext<GameWatchContextType | null>(null);
+
+export function GameWatchProvider({ children }: { children: ReactNode }) {
+  const [storedSettings, setStoredSettings] = useLocalStorage<GameWatchSettings>(
+    'gameWatchSettings',
+    defaultSettings,
+  );
+  const settings = { ...defaultSettings, ...storedSettings };
+  const { aiState } = useAiState();
+  const { wsState } = useWebSocket();
+  const {
+    stream, isStreaming, startCapture,
+  } = useScreenCaptureContext();
+  const { sendTriggerSignal } = useTriggerSpeak();
+  const intervalRef = useRef<ReturnType<typeof setInterval> | null>(null);
+  const lastTriggerRef = useRef<number | null>(null);
+
+  const clearTimer = useCallback(() => {
+    if (intervalRef.current) clearInterval(intervalRef.current);
+    intervalRef.current = null;
+  }, []);
+
+  useEffect(() => {
+    if (settings.enabled && settings.autoStartScreenCapture && !isStreaming) {
+      startCapture();
+    }
+  }, [settings.enabled, settings.autoStartScreenCapture, isStreaming, startCapture]);
+
+  const triggerObservation = useCallback(async () => {
+    if (!settings.enabled || aiState !== AiStateEnum.IDLE || wsState !== 'OPEN') return;
+    if (!stream && settings.autoStartScreenCapture && !isStreaming) await startCapture();
+    if (!stream && !isStreaming) return;
+
+    const now = Date.now();
+    const idleSeconds = lastTriggerRef.current
+      ? (now - lastTriggerRef.current) / 1000
+      : settings.intervalSeconds;
+    lastTriggerRef.current = now;
+    await sendTriggerSignal(
+      idleSeconds,
+      { game_watch: true, comment_style: settings.commentStyle },
+      { camera: false, screen: true },
+    );
+  }, [
+    settings.enabled, settings.autoStartScreenCapture, settings.commentStyle,
+    settings.intervalSeconds, aiState, wsState, stream, isStreaming,
+    startCapture, sendTriggerSignal,
+  ]);
+
+  useEffect(() => {
+    clearTimer();
+    if (!settings.enabled || aiState !== AiStateEnum.IDLE || wsState !== 'OPEN') {
+      return clearTimer;
+    }
+    intervalRef.current = setInterval(
+      triggerObservation,
+      Math.max(10, settings.intervalSeconds) * 1000,
+    );
+    return clearTimer;
+  }, [
+    settings.enabled, settings.intervalSeconds, aiState, wsState,
+    triggerObservation, clearTimer,
+  ]);
+
+  useEffect(() => clearTimer, [clearTimer]);
+
+  const updateSettings = useCallback((newSettings: GameWatchSettings) => {
+    setStoredSettings({
+      ...defaultSettings,
+      ...newSettings,
+      intervalSeconds: Math.max(
+        10,
+        Number(newSettings.intervalSeconds) || defaultSettings.intervalSeconds,
+      ),
+    });
+  }, [setStoredSettings]);
+
+  const value = useMemo(
+    () => ({ settings, updateSettings }),
+    [settings, updateSettings],
+  );
+
+  return (
+    <GameWatchContext.Provider value={value}>
+      {children}
+    </GameWatchContext.Provider>
+  );
+}
+
+export function useGameWatch() {
+  const context = useContext(GameWatchContext);
+  if (!context) throw new Error('useGameWatch must be used within a GameWatchProvider');
+  return context;
+}
